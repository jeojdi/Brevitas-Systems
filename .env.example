# Copy this file to .env.local and fill in your values
# Get these from: https://app.supabase.com/project/YOUR_PROJECT/settings/api

# Supabase Public Configuration (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# PostHog US Cloud. The project token is intentionally public; the personal key is server-only.
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_your_project_token
NEXT_PUBLIC_POSTHOG_UI_HOST=https://us.posthog.com
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_ASSETS_HOST=https://us-assets.i.posthog.com
POSTHOG_PROJECT_ID=your_numeric_project_id
POSTHOG_PERSONAL_API_KEY=
POSTHOG_API_HOST=https://us.posthog.com

# Supabase Service Role Key (KEEP SECRET! Never commit this!)
# Only needed for server-side operations
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Stripe usage billing (server-only; never prefix these with NEXT_PUBLIC_)
# Run `STRIPE_SECRET_KEY=sk_test_... npm run billing:setup` to create the sandbox meter/price.
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_ID=price_your_metered_price
STRIPE_METER_EVENT_NAME=brevitas_fee_microusd
# Required fail-closed operator ceiling per customer billing period.
BREVITAS_BILLING_MONTHLY_CAP_USD=100
BREVITAS_PUBLIC_URL=https://brevitassystems.com
STRIPE_AUTOMATIC_TAX=false
# Used by Vercel Cron to authorize /api/billing/sync.
CRON_SECRET=generate_a_long_random_value

# Railway Brevitas API/proxy
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
BREVITAS_SECRET_KEY=generate_a_fernet_key_and_keep_it_stable
BREVITAS_STORE=supabase
ALLOWED_ORIGINS=https://your-vercel-domain.example
BREVITAS_PROXY_AUTH=true
BREVITAS_PROXY_RPM=300
BREVITAS_PROXY_CONCURRENCY=20
BREVITAS_SEMANTIC_CACHE=false
BREVITAS_COMPRESS_URL=
BREVITAS_COMPRESS_TOKEN=
