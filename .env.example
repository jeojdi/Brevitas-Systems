# Copy this file to .env.local and fill in your values
# Get these from: https://app.supabase.com/project/YOUR_PROJECT/settings/api

# Supabase Public Configuration (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# PostHog US Cloud. The project token is intentionally public; the personal key is server-only.
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_your_project_token
NEXT_PUBLIC_POSTHOG_UI_HOST=https://us.posthog.com
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_ASSETS_HOST=https://us-assets.i.posthog.com
POSTHOG_PROJECT_ID=your_numeric_project_id
POSTHOG_PERSONAL_API_KEY=
POSTHOG_API_HOST=https://us.posthog.com

# OpenTelemetry (server-side only). Keep disabled until an OTLP collector/provider is configured.
BREVITAS_OTEL_ENABLED=false
OTEL_SDK_DISABLED=false
OTEL_SERVICE_NAME=api
# Optional opaque UUID/hex ID; Railway replicas otherwise generate one per process.
OTEL_SERVICE_INSTANCE_ID=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# Configure provider auth as a managed secret; never expose this through NEXT_PUBLIC_*.
OTEL_EXPORTER_OTLP_HEADERS=
BREVITAS_OTEL_MAX_QUEUE_SIZE=2048
BREVITAS_OTEL_MAX_EXPORT_BATCH_SIZE=256
BREVITAS_OTEL_SCHEDULE_DELAY_MS=5000
BREVITAS_OTEL_EXPORT_TIMEOUT_MS=5000
BREVITAS_OTEL_METRIC_INTERVAL_MS=60000
BREVITAS_LOG_LEVEL=INFO

# Supabase Service Role Key (KEEP SECRET! Never commit this!)
# Only needed for server-side operations
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Stripe usage billing (server-only; never prefix these with NEXT_PUBLIC_)
# Run `STRIPE_SECRET_KEY=sk_test_... npm run billing:setup` to create the sandbox meter/price.
# Keep false until migrations, webhooks, and the authoritative Railway worker pass readiness.
BREVITAS_BILLING_ENABLED=false
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_ID=price_your_metered_price
STRIPE_METER_EVENT_NAME=brevitas_fee_microusd
# Required fail-closed operator ceiling per customer seven-day Stripe period.
BREVITAS_BILLING_WEEKLY_CAP_USD=100
BREVITAS_PUBLIC_URL=https://brevitassystems.com
STRIPE_AUTOMATIC_TAX=false
# Dedicated manual-recovery second factor. Generate with `openssl rand -base64 32`.
# ASCII only, 32-256 bytes, server-only; there is no cron-secret fallback.
BILLING_RECOVERY_SECRET=
# Railway authoritative billing-worker recovery bounds. Other worker services set role=nonbilling.
# One entry per claim preserves Stripe reconciliation safety.
BREVITAS_WORKER_BILLING_ROLE=authoritative
BREVITAS_BILLING_POLL_SECONDS=5
BREVITAS_BILLING_LEASE_SECONDS=120
BREVITAS_BILLING_BATCH_SIZE=1
BREVITAS_BILLING_HTTP_TIMEOUT_SECONDS=10
BREVITAS_BILLING_LAG_ALERT_SECONDS=300
BREVITAS_BILLING_REVIEW_ALERT_COUNT=1
BREVITAS_BILLING_DEAD_ALERT_COUNT=1
# Change to true only after proving this worker is the sole Stripe meter-event writer.
BREVITAS_STRIPE_METER_EXCLUSIVE_WRITER=false
BREVITAS_BILLING_RECONCILIATION_MAX_PAGES=20
BREVITAS_BILLING_WORKER_ID=billing

# Railway Brevitas API/proxy
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
BREVITAS_STORE=supabase
ALLOWED_ORIGINS=https://your-vercel-domain.example
BREVITAS_PROXY_AUTH=true
# Required on every API replica for company pagination and email-bound invites.
# Generate two different random values of at least 32 characters each.
COMPANY_ADMIN_CURSOR_SECRET=
COMPANY_ADMIN_INVITEE_PEPPER=
BREVITAS_PROXY_RPM=300
BREVITAS_PROXY_CONCURRENCY=20
BREVITAS_PROVIDER_CONNECT_TIMEOUT_S=5
BREVITAS_PROVIDER_READ_TIMEOUT_S=120
BREVITAS_PROVIDER_WRITE_TIMEOUT_S=30
BREVITAS_PROVIDER_POOL_TIMEOUT_S=5
BREVITAS_PROVIDER_MAX_CONNECTIONS=100
BREVITAS_PROVIDER_MAX_KEEPALIVE=20
BREVITAS_PROVIDER_KEEPALIVE_EXPIRY_S=30
BREVITAS_PROVIDER_MAX_RETRIES=2
BREVITAS_PROVIDER_RETRY_BASE_S=0.25
BREVITAS_PROVIDER_RETRY_MAX_S=8
BREVITAS_PROVIDER_CIRCUIT_FAILURES=5
BREVITAS_PROVIDER_CIRCUIT_OPEN_S=30
BREVITAS_PROVIDER_CIRCUIT_TTL_S=900
BREVITAS_PROVIDER_MAX_STATES=32
BREVITAS_PROVIDER_CLOSE_DRAIN_SECONDS=10
# Operations-controlled SLA exclusion. Set both only for a verified/documented incident;
# ordinary provider errors, timeouts, and circuit opens remain Brevitas/SLA-eligible.
BREVITAS_DOCUMENTED_UPSTREAM_OUTAGES=
BREVITAS_DOCUMENTED_UPSTREAM_OUTAGE_REFERENCE=
BREVITAS_AUTH_CONTEXT_CACHE_MAX=10000
REDIS_URL=
BREVITAS_ENV=development

# Root Next.js deployment: forwards /v1 and the company-admin BFF to Railway.
API_URL=http://localhost:8000

# Provider credentials and durable-job payloads use envelope encryption with a
# deployment-supplied managed-KMS adapter. Production enforces KMS_REQUIRED=true.
BREVITAS_KMS_REQUIRED=true
BREVITAS_KMS_PROVIDER=google-cloud-kms
BREVITAS_KMS_KEY_ID=projects/your-project/locations/global/keyRings/brevitas-production/cryptoKeys/credential-envelope
# Must identify an immutable key version; latest/current/active/default and aliases are rejected.
BREVITAS_KMS_KEY_VERSION=1
BREVITAS_KMS_ALGORITHM=GOOGLE_SYMMETRIC_ENCRYPTION
# Either exact allowlisted module:factory plus its module allowlist, or registry:factory_name.
BREVITAS_KMS_ADAPTER_FACTORY=brevitas.security.google_cloud_kms:create_adapter
BREVITAS_KMS_ADAPTER_TRUSTED_MODULES=brevitas.security.google_cloud_kms
BREVITAS_GCP_KMS_TIMEOUT_SECONDS=0.75
BREVITAS_DATA_KEY_CACHE_TTL_SECONDS=300
BREVITAS_DATA_KEY_CACHE_MAX_ENTRIES=256
# Content-free active KMS round-trip used by API and worker readiness.
BREVITAS_KMS_READINESS_TIMEOUT_SECONDS=1
BREVITAS_KMS_READINESS_MAX_AGE_SECONDS=30
# Development/test only. Leave empty for managed KMS; any value is forbidden in production.
BREVITAS_LOCAL_KMS_KEY=

BREVITAS_JOB_STREAM=brevitas:jobs
BREVITAS_WORKER_CONCURRENCY=10
BREVITAS_JOB_POLL_SECONDS=0.25
BREVITAS_JOB_LEASE_SECONDS=180
BREVITAS_WORKER_HEALTH_INTERVAL=5
BREVITAS_HEALTH_TIMEOUT_SECONDS=3
BREVITAS_WORKER_DRAIN_SECONDS=120
BREVITAS_ORG_RPM=3000
BREVITAS_CUSTOMER_RPM=300
BREVITAS_KEY_RPM=300
BREVITAS_ORG_TPM=2000000
BREVITAS_CUSTOMER_TPM=200000
BREVITAS_ORG_CONCURRENCY=200
BREVITAS_CUSTOMER_CONCURRENCY=20
BREVITAS_SEMANTIC_CACHE=false
BREVITAS_CACHE_ENABLED=false
BREVITAS_CACHE_BACKEND=supabase
BREVITAS_CACHE_ENCRYPTION_KEY=
BREVITAS_COMPRESS_URL=
BREVITAS_COMPRESS_TOKEN=
BREVITAS_COMPRESS_CONCURRENCY=2
BREVITAS_COMPRESS_MAX_PROMPT_CHARS=1000000
BREVITAS_COMPRESS_ADMISSION_TIMEOUT=0.25
BREVITAS_COMPRESS_INFERENCE_TIMEOUT=120
