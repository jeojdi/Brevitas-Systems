# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
node_modules/
dashboard/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local
.env.production
.env.development
# Allow the example file
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Test and setup files - NEVER commit these
test-*.js
setup-*.js
*-test.js
*-setup.js
*.test.js
*.setup.js

# build artifacts - NEVER commit these
dist/

# python
__pycache__/
*.pyc

# secrets & local databases - NEVER commit these
.secret_key
*.db

# token_efficiency_model runtime cache
token_efficiency_model/experiments/.delta_memory_store.json

# api runtime artifacts / secrets (added during PR #5 merge cleanup)
api/.secret_key
api/brevitas.db
api/__pycache__/
**/__pycache__/
*.pyc
dashboard/node_modules/

# large source GIFs (converted to MP4 for web — keep only the mp4s)
public/assets/*.gif

# Python build artifacts
*.egg-info/

ponytail/